{"cells":[{"cell_type":"code","execution_count":null,"metadata":{},"outputs":[],"source":["# QPSK Experiment\n\nimport numpy as np\nimport matplotlib.pyplot as plt\n\n# Define parameters\nnum_symbols = 1000\nEb_N0_dB = np.arange(0, 11, 1)\n\n# Simulate QPSK\nfor eb_no in Eb_N0_dB:\n    # Generate random data symbols\n    data = np.random.randint(0, 4, num_symbols)\n    # Map symbols to QPSK\n    qpsk_symbols = (data%2)*2 + 1j*(data//2)*2 - 1 - 1j\n    # Transmit symbols\n    noise = (1/np.sqrt(2))*(np.random.randn(num_symbols) + 1j*np.random.randn(num_symbols))\n    received_symbols = qpsk_symbols + 10**(-eb_no/20)*noise\n    \n    # Demodulate received symbols\n    demodulated_data = np.zeros(num_symbols)\n    demodulated_data[np.angle(received_symbols)<0] = 0\n    demodulated_data[np.angle(received_symbols)>=0] = 1\n    \n    # Calculate Bit Error Rate (BER)\n    BER = np.sum(data != demodulated_data) / num_symbols\n    print(f'Eb/N0: {eb_no} dB, BER: {BER}')\n\n# Plot results\nplt.semilogy(Eb_N0_dB, BER, 'o-')\nplt.title('QPSK BER vs Eb/N0')\nplt.xlabel('Eb/N0 (dB)')\nplt.ylabel('Bit Error Rate (BER)')\nplt.grid(True)\nplt.show()"}